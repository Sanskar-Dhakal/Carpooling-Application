# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vroomsquad
DB_USER=postgres
DB_PASS=postgres

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380

# JWT
JWT_SECRET=vroom_squad_jwt_secret_change_in_prod
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=vroom_squad_refresh_secret_change_in_prod
JWT_REFRESH_EXPIRES_IN=7d

# Email (Nodemailer / Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_app_password

# App URL (used in email verification links)
APP_URL=http://localhost:3000

# MinIO (object storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Firebase Admin (for FCM push notifications)
FIREBASE_PROJECT_ID=vroom-squad
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json
